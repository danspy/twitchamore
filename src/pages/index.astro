---
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TwitchAmore – Multi-Stream Viewer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Twitch Embed SDK (is:inline keeps it as a classic script so window.Twitch is set) -->
    <script is:inline src="https://embed.twitch.tv/embed/v1.js"></script>
    <style is:global>
      /* ── Reset & base ───────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #0e0e10;
        --bg-header:   #18181b;
        --bg-card:     #1f1f23;
        --border:      #2d2d35;
        --accent:      #9147ff;
        --accent-hov:  #a970ff;
        --text:        #efeff1;
        --text-dim:    #adadb8;
        --danger:      #e91916;
        --header-h:    58px;
        --bar-h:       52px;
      }

      html, body { min-height: 100%; }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow-y: auto;
        overflow-x: hidden;
      }

      /* ── App shell ──────────────────────────────────────────── */
      #app {
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
        padding-top: var(--header-h);
        padding-bottom: var(--bar-h);
      }

      /* ── Header ─────────────────────────────────────────────── */
      .header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 16px;
        height: var(--header-h);
        background: var(--bg-header);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--accent);
        white-space: nowrap;
        text-decoration: none;
      }
      .logo svg { flex-shrink: 0; }

      .add-form {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        max-width: 100%;
      }

      .add-form-wrap {
        position: relative;
        flex: 1;
        max-width: 480px;
      }

      .add-form input {
        flex: 1;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text);
        padding: 7px 12px;
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.15s;
      }
      .add-form input:focus { border-color: var(--accent); }
      .add-form input::placeholder { color: var(--text-dim); }

      .search-suggest {
        display: none;
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        z-index: 250;
        max-height: 280px;
        overflow-y: auto;
      }

      .search-suggest.open { display: block; }

      .suggest-item {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 8px 10px;
        border: none;
        border-top: 1px solid var(--border);
        background: transparent;
        color: var(--text);
        text-align: left;
        cursor: pointer;
      }

      .suggest-item:first-child { border-top: none; }
      .suggest-item:hover,
      .suggest-item.active { background: rgba(145,71,255,0.16); }

      .suggest-main {
        display: flex;
        flex-direction: column;
        min-width: 0;
      }

      .suggest-name {
        font-size: 0.88rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .suggest-login {
        font-size: 0.78rem;
        color: var(--text-dim);
      }

      .suggest-status {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 999px;
        border: 1px solid var(--border);
        flex-shrink: 0;
      }

      .suggest-status.live {
        color: #fff;
        background: var(--danger);
        border-color: var(--danger);
      }

      .suggest-empty {
        padding: 9px 10px;
        font-size: 0.8rem;
        color: var(--text-dim);
      }

      .header-auth { margin-left: auto; }

      /* ── Buttons ─────────────────────────────────────────────── */
      .btn {
        cursor: pointer;
        border: none;
        border-radius: 4px;
        font-size: 0.875rem;
        font-weight: 600;
        padding: 7px 14px;
        transition: background 0.15s, opacity 0.15s;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 3px;
      }
      .btn-primary { background: var(--accent); color: #fff; }
      .btn-primary:hover { background: var(--accent-hov); }
      .btn-sm { padding: 5px 10px; font-size: 0.8rem; }
      .btn-ghost {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-dim);
      }
      .btn-ghost:hover { border-color: var(--text-dim); color: var(--text); }

      .icon-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 4px 6px;
        border-radius: 4px;
        font-size: 1rem;
        color: var(--text);
        transition: background 0.15s;
        line-height: 1;
      }
      .icon-btn:hover { background: rgba(255,255,255,0.12); }
      .icon-btn.muted  { opacity: 0.55; }
      .icon-btn.staged { color: var(--accent); }
      .icon-btn.wide   { color: var(--accent); }
      .wide-btn { display: none; }
      .wide-btn {
        font-size: 1.2rem;
        padding: 3px 7px;
      }
      .stream-card.is-stage .wide-btn,
      .ctrl-item.is-stage .wide-btn { display: inline-flex; }

      /* ── Main ────────────────────────────────────────────────── */
      .content-wrap {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        position: relative;
      }

      .main {
        flex: 1;
        overflow: visible;
        min-height: 0;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      /* ── Empty state ─────────────────────────────────────────── */
      #empty-state {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        color: var(--text-dim);
        pointer-events: none;
      }
      #empty-state .empty-icon { font-size: 3rem; }
      #empty-state p { font-size: 1rem; }
      #empty-state small { font-size: 0.8rem; }

      /* ── Streams container ───────────────────────────────────── */
      #streams {
        width: 100%;
        background: #000;
      }

      #streams.grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
        gap: 2px;
      }

      #streams.stage {
        display: grid;
        grid-template-columns: 3fr 1fr;
        gap: 2px;
      }

      #streams.wide-stage {
        display: grid;
        gap: 2px;
        /* grid-template-columns and grid-template-rows set by JS */
      }

      #streams.full-stage {
        display: grid;
        gap: 2px;
      }

      /* ── Stream card ─────────────────────────────────────────── */
      .stream-card {
        position: relative;
        background: #000;
        overflow: hidden;
        aspect-ratio: 16 / 9;
        min-height: 0;
      }

      .embed-wrap {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      /* Twitch SDK injects a wrapper div — make it fill too */
      .embed-wrap > div {
        width: 100%;
        height: 100%;
      }

      /* Twitch embed iframe fills the wrap */
      .embed-wrap iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: none;
      }

      /* Overlay fades in on hover */
      .card-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 8px;
        opacity: 0;
        transition: opacity 0.2s;
        pointer-events: none;
        background: linear-gradient(
          to bottom,
          rgba(0,0,0,0.65) 0%,
          transparent 35%,
          transparent 65%,
          rgba(0,0,0,0.5) 100%
        );
      }
      .stream-card:hover .card-overlay { opacity: 1; }

      .overlay-top,
      .overlay-bottom {
        display: flex;
        align-items: center;
        pointer-events: all;
      }
      .overlay-top { justify-content: space-between; }
      .overlay-bottom { justify-content: flex-start; }

      .card-label {
        font-weight: 700;
        font-size: 0.875rem;
        text-shadow: 0 1px 3px rgba(0,0,0,0.9);
      }
      .card-actions { display: flex; gap: 2px; }

      /* Stage border highlight */
      .stream-card.is-stage::after {
        content: '';
        position: absolute;
        inset: 0;
        border: 2px solid var(--accent);
        pointer-events: none;
      }

      /* ── Control bar ─────────────────────────────────────────── */
      #ctrl-bar {
        display: none;
        align-items: center;
        gap: 4px;
        padding: 0 12px;
        height: var(--bar-h);
        background: var(--bg-header);
        border-top: 1px solid var(--border);
        flex-shrink: 0;
        overflow-x: auto;
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 200;
      }
      #ctrl-bar::-webkit-scrollbar { height: 4px; }
      #ctrl-bar::-webkit-scrollbar-thumb { background: var(--border); }

      .ctrl-item {
        display: flex;
        align-items: center;
        gap: 3px;
        padding: 4px 10px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        white-space: nowrap;
        flex-shrink: 0;
        cursor: grab;
      }
      .ctrl-clear-all {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 4px 10px;
        height: 34px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text-dim);
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
        margin-right: 6px;
        flex-shrink: 0;
      }
      .ctrl-clear-all:hover {
        border-color: var(--text-dim);
        color: var(--text);
      }
      .ctrl-item:active { cursor: grabbing; }
      .ctrl-item.is-stage { border-color: var(--accent); }
      .ctrl-item.dragging { opacity: 0.35; }
      .ctrl-item.drag-over { border-color: var(--accent); background: rgba(145,71,255,0.18); }

      .ctrl-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-dim);
        margin-right: 4px;
        max-width: 120px;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      /* ── Mobile add-bar ──────────────────────────────────────── */
      #add-toggle-btn { display: none; }

      #add-bar {
        display: none;
        align-items: center;
        padding: 0 16px;
        height: var(--bar-h);
        background: var(--bg-header);
        border-bottom: 1px solid var(--border);
        position: fixed;
        top: var(--header-h);
        left: 0;
        right: 0;
        z-index: 190;
      }
      #add-bar.open { display: flex; }
      #add-bar .add-form-wrap { flex: 1; max-width: 100%; }
      #add-bar .add-form { flex: 1; max-width: 100%; }

      /* ── Responsive tweaks ───────────────────────────────────── */
      @media (max-width: 768px) {
        #streams.grid {
          grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        }
      }

      @media (max-width: 900px) {
        .logo span { display: none; }
        .header .add-form-wrap { display: none; }
        #add-toggle-btn { display: inline-flex; }
        #layout-btn { display: none; }
        .btn-text { display: none; }
        .header { gap: 8px; padding: 0 10px; }

        /* Prevent mobile browsers from zooming on focused inputs */
        .add-form input {
          font-size: 16px;
        }
      }

      /* ── Focus-visible ───────────────────────────────────────── */
      .btn:focus-visible,
      .icon-btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .add-form input:focus-visible {
        border-color: var(--accent);
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .ctrl-item:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      /* ── Chat sidebar ────────────────────────────────────────── */
      #chat-sidebar {
        position: fixed;
        top: var(--header-h);
        right: -340px;
        width: 340px;
        height: calc(100dvh - var(--header-h) - var(--bar-h));
        background: var(--bg-header);
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        z-index: 150;
        transition: right 0.25s ease;
        box-shadow: -4px 0 16px rgba(0,0,0,0.4);
      }

      #chat-sidebar.open { right: 0; }

      .chat-sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 12px;
        height: 44px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        gap: 8px;
      }

      .chat-sidebar-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-dim);
        white-space: nowrap;
      }

      .chat-tabs {
        display: flex;
        gap: 4px;
        overflow-x: auto;
        flex: 1;
        scrollbar-width: none;
        padding: 0 2px;
      }
      .chat-tabs::-webkit-scrollbar { display: none; }

      .chat-tab {
        background: transparent;
        border: 1px solid transparent;
        border-radius: 4px;
        color: var(--text-dim);
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 3px 9px;
        white-space: nowrap;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        flex-shrink: 0;
      }
      .chat-tab:hover { background: rgba(255,255,255,0.08); color: var(--text); }
      .chat-tab.active {
        background: rgba(145,71,255,0.18);
        border-color: var(--accent);
        color: var(--text);
      }

      .chat-body {
        flex: 1;
        overflow: hidden;
        position: relative;
      }

      .chat-body iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: none;
      }

      .chat-empty {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: var(--text-dim);
        font-size: 0.85rem;
        pointer-events: none;
      }
      .chat-empty .chat-empty-icon { font-size: 2rem; }

      #chat-btn.chat-active {
        background: rgba(145,71,255,0.2);
        border-color: var(--accent);
        color: var(--text);
      }

      /* Pin button — hidden on mobile, shown on tablet/desktop */
      #chat-pin-btn { display: none; }

      @media (min-width: 601px) {
        #chat-pin-btn { display: inline-flex; }
        #chat-pin-btn.pinned { color: var(--accent); }
      }

      /* ── Pinned mode (tablet/desktop only) ───────────────────── */
      @media (min-width: 601px) {
        #app.chat-pinned .content-wrap {
          flex-direction: row;
        }
        #app.chat-pinned #chat-sidebar {
          position: sticky;
          top: var(--header-h);
          right: auto;
          height: calc(100dvh - var(--header-h) - var(--bar-h));
          box-shadow: none;
          transition: none;
          flex-shrink: 0;
        }
      }

      @media (max-width: 600px) {
        #chat-sidebar {
          width: 100%;
          right: -100%;
          border-left: none;
          border-top: 1px solid var(--border);
        }
        #chat-sidebar.open { right: 0; }
      }
    </style>
  </head>

  <body>
    <div id="app">
      <!-- ── Header ──────────────────────────────────────────── -->
      <header class="header">
        <a class="logo" href="/" aria-label="TwitchAmore – Multi-Stream Viewer">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/>
          </svg>
          <span>TwitchAmore</span>
        </a>

        <div class="add-form-wrap">
          <form class="add-form" id="add-form" autocomplete="off">
            <input
              id="channel-input"
              type="text"
              placeholder="Channel name…"
              maxlength="25"
              aria-label="Twitch channel name"
              spellcheck="false"
            />
            <button type="submit" class="btn btn-primary btn-sm">Add Stream</button>
          </form>
          <div class="search-suggest" id="search-suggest" role="listbox" aria-label="Channel suggestions"></div>
        </div>

        <div style="display:flex;gap:6px;margin-left:auto;flex-shrink:0;">
          <button class="btn btn-primary btn-sm" id="add-toggle-btn" title="Add stream" aria-label="Add stream" aria-expanded="false">+</button>
          <button class="btn btn-ghost btn-sm" id="chat-btn" title="Open chat sidebar" aria-expanded="false" aria-controls="chat-sidebar"><span class="btn-icon">💬</span><span class="btn-text">Chat</span></button>
          <button class="btn btn-ghost btn-sm" id="layout-btn" title="Switch between stage and grid layout"><span class="btn-icon">⊞</span><span class="btn-text">Grid</span></button>
          <button class="btn btn-ghost btn-sm" id="mute-all-btn" title="Mute / unmute all streams"><span class="btn-icon">🔇</span><span class="btn-text">Mute All</span></button>
          <button class="btn btn-ghost btn-sm" id="export-btn" title="Export layout to JSON"><span class="btn-icon">⬇</span><span class="btn-text">Export</span></button>
          <button class="btn btn-ghost btn-sm" id="import-btn" title="Import layout from JSON"><span class="btn-icon">⬆</span><span class="btn-text">Import</span></button>
          <input type="file" id="import-file" accept=".json" style="display:none" aria-hidden="true">
        </div>
      </header>

      <!-- ── Mobile add bar ──────────────────────────────────── -->
      <div id="add-bar" aria-hidden="true">
        <div class="add-form-wrap">
          <form id="add-form-mobile" class="add-form" autocomplete="off">
            <input
              id="channel-input-mobile"
              type="text"
              placeholder="Channel name…"
              maxlength="25"
              aria-label="Twitch channel name"
              spellcheck="false"
            />
            <button type="submit" class="btn btn-primary btn-sm">Add</button>
          </form>
          <div class="search-suggest" id="search-suggest-mobile" role="listbox" aria-label="Channel suggestions"></div>
        </div>
      </div>

      <!-- ── Main area + Chat sidebar (wrapped for pinned layout) ─ -->
      <div class="content-wrap">
        <main class="main" id="main">
          <!-- Empty state -->
          <div id="empty-state">
            <span class="empty-icon">🎮</span>
            <p>Add a channel above to start watching!</p>
            <small>Type a Twitch username and press Enter or click "Add Stream"</small>
          </div>

          <!-- Stream cards are inserted here by JS -->
          <div id="streams" class="grid" role="region" aria-label="Active streams"></div>
        </main>

        <!-- ── Chat sidebar ──────────────────────────────────── -->
        <aside id="chat-sidebar" aria-label="Chat sidebar" aria-hidden="true">
          <div class="chat-sidebar-header">
            <span class="chat-sidebar-title">Chat</span>
            <div class="chat-tabs" id="chat-tabs" role="tablist" aria-label="Select stream chat"></div>
            <button class="icon-btn" id="chat-pin-btn" title="Pin sidebar" aria-label="Pin chat sidebar">📌</button>
            <button class="icon-btn" id="chat-close-btn" title="Close chat" aria-label="Close chat sidebar">✕</button>
          </div>
          <div class="chat-body" id="chat-body"></div>
        </aside>
      </div>

      <!-- ── Control bar ──────────────────────────────────────── -->
      <footer id="ctrl-bar" aria-label="Stream controls"></footer>
    </div>

    <script>
      /* ────────────────────────────────────────────────────────────
       *  TwitchAmore – client-side logic
       * ──────────────────────────────────────────────────────────── */

      // ── State ──────────────────────────────────────────────────
      let streams      = [];       // string[] – ordered channel list
      let stageChannel = null;     // string | null
      let mutedSet     = new Set();
      let embeds       = {};       // { [ch]: { embed, player } }
      let dragSrc      = null;     // channel being dragged in ctrl-bar
      let layoutMode   = 'stage';  // 'stage' | 'grid'
      let stageFullWidth = false;  // full-width override for current staged stream
      let chatOpen     = false;    // whether chat sidebar is open
      let chatChannel  = null;     // channel whose chat is shown in sidebar
      let chatPinned   = false;    // whether sidebar is pinned beside streams (tablet/desktop only)
      const TWITCH_GQL_CLIENT_ID = 'kimne78kx3ncx6brgo4mv6wki5h1ko';
      const SEARCH_QUERY = `query ChannelTypeahead($q: String!) {
        searchFor(userQuery: $q, platform: "web") {
          channels {
            edges {
              item {
                ... on User {
                  login
                  displayName
                  stream { id }
                }
              }
            }
          }
        }
      }`;

      // ── Persistence ────────────────────────────────────────────
      function save() {
        try {
          localStorage.setItem('ta_streams', JSON.stringify(streams));
          localStorage.setItem('ta_muted',   JSON.stringify([...mutedSet]));
          localStorage.setItem('ta_layout',  layoutMode);
          localStorage.setItem('ta_stage_fullwidth', String(stageFullWidth));
          localStorage.setItem('ta_chat_open', String(chatOpen));
          localStorage.setItem('ta_chat_pinned', String(chatPinned));
          if (stageChannel) localStorage.setItem('ta_stage', stageChannel);
          else               localStorage.removeItem('ta_stage');
          if (chatChannel)  localStorage.setItem('ta_chat_ch', chatChannel);
          else              localStorage.removeItem('ta_chat_ch');
        } catch (_) {}
      }

      function load() {
        try {
          streams      = JSON.parse(localStorage.getItem('ta_streams') || '[]');
          mutedSet     = new Set(JSON.parse(localStorage.getItem('ta_muted') || '[]'));
          stageChannel = localStorage.getItem('ta_stage') || null;
          layoutMode   = localStorage.getItem('ta_layout') || 'stage';
          stageFullWidth = localStorage.getItem('ta_stage_fullwidth') === 'true';
          chatOpen     = localStorage.getItem('ta_chat_open') === 'true';
          chatChannel  = localStorage.getItem('ta_chat_ch') || null;
          chatPinned   = localStorage.getItem('ta_chat_pinned') === 'true';
          if (stageChannel && !streams.includes(stageChannel)) stageChannel = null;
          if (!stageChannel) stageFullWidth = false;
          if (chatChannel && !streams.includes(chatChannel)) chatChannel = null;
        } catch (_) {
          streams = []; mutedSet = new Set(); stageChannel = null; layoutMode = 'stage'; stageFullWidth = false;
          chatOpen = false; chatChannel = null; chatPinned = false;
        }
      }

      // ── Stream management ──────────────────────────────────────
      function addStream(raw) {
        const channel = raw.trim().toLowerCase();
        if (!channel) return;
        if (streams.includes(channel)) {
          alert(`"${channel}" is already in your stream list.`);
          return;
        }
        mutedSet.add(channel);
        streams.push(channel);
        save();
        createCard(channel);
        updateEmpty();
        applyLayout();
        renderBar();
        updateChatSidebar();
      }

      function removeStream(channel) {
        const wasStage = stageChannel === channel;
        streams = streams.filter(c => c !== channel);
        mutedSet.delete(channel);
        if (wasStage) {
          stageChannel = null;
          stageFullWidth = false;
          // Unmute the new first stream so audio isn't silently lost
          if (streams.length > 0) {
            mutedSet.delete(streams[0]);
            setMuted(streams[0], false);
          }
        }
        delete embeds[channel];
        document.getElementById(`card-${channel}`)?.remove();
        save();
        updateEmpty();
        applyLayout();
        renderBar();
        updateChatSidebar();
      }

      function clearAllStreams() {
        if (streams.length === 0) return;
        [...streams].forEach(ch => {
          document.getElementById(`card-${ch}`)?.remove();
          delete embeds[ch];
        });
        streams = [];
        mutedSet = new Set();
        stageChannel = null;
        stageFullWidth = false;
        chatChannel = null;
        chatOpen = false;
        chatPinned = false;
        save();
        updateEmpty();
        applyLayout();
        renderBar();
        updateChatSidebar();
      }

      function toggleMute(channel) {
        if (mutedSet.has(channel)) {
          mutedSet.delete(channel);
          setMuted(channel, false);
        } else {
          mutedSet.add(channel);
          setMuted(channel, true);
        }
        save();
        refreshMuteUI(channel);
      }

      function setMuted(channel, muted) {
        embeds[channel]?.player?.setMuted(muted);
      }

      function snapToLive(channel) {
        const player = embeds[channel]?.player;
        if (!player) return;
        // Seek to a huge value — on a live stream this snaps to the live edge
        try { player.seek(999999); } catch (_) {}
        try { player.play(); } catch (_) {}
      }

      function getHeaderOffset() {
        const header = document.querySelector('.header');
        if (!(header instanceof HTMLElement)) return 0;
        return header.offsetHeight;
      }

      function scrollCardIntoViewWithHeader(channel) {
        const card = document.getElementById(`card-${channel}`);
        if (!(card instanceof HTMLElement)) return;
        const top = window.scrollY + card.getBoundingClientRect().top - getHeaderOffset();
        window.scrollTo({ top: Math.max(0, top - 2), behavior: 'smooth' });
      }

      function setStage(channel) {
        const prevStage = stageChannel;
        stageChannel = stageChannel === channel ? null : channel;
        if (!stageChannel || stageChannel !== prevStage) stageFullWidth = false;

        let postLayoutScroll = null;

        if (stageChannel) {
          if (window.innerWidth >= 900) {
            // Desktop: respect layout mode
            if (layoutMode === 'stage') {
              postLayoutScroll = 'top';
            } else {
              postLayoutScroll = 'card';
            }
          } else if (window.innerWidth >= 600) {
            // Tablet: stage always at row 1, scroll to top
            postLayoutScroll = 'top';
          } else {
            // Mobile: scroll to card
            postLayoutScroll = 'card';
          }
          // Unmute the staged stream, mute everything else
          streams.forEach(ch => {
            if (ch === stageChannel) {
              mutedSet.delete(ch);
              setMuted(ch, false);
            } else {
              mutedSet.add(ch);
              setMuted(ch, true);
            }
            refreshMuteUI(ch);
          });
          // Snap staged stream back to live edge (background streams fall behind)
          snapToLive(stageChannel);
        }

        // When a stream is staged, follow it in the chat sidebar
        if (stageChannel) chatChannel = stageChannel;
        save();
        applyLayout();
        renderBar();
        updateChatSidebar();

        if (postLayoutScroll === 'top') {
          requestAnimationFrame(() => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        } else if (postLayoutScroll === 'card' && stageChannel) {
          requestAnimationFrame(() => {
            scrollCardIntoViewWithHeader(stageChannel);
          });
        }
      }

      function toggleStageFullWidth(channel) {
        if (!stageChannel || stageChannel !== channel) return;
        const nextStageFullWidth = !stageFullWidth;
        stageFullWidth = nextStageFullWidth;
        save();
        applyLayout();
        renderBar();
        if (stageFullWidth && layoutMode === 'grid') {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else if (!nextStageFullWidth && layoutMode === 'grid' && stageChannel) {
          scrollCardIntoViewWithHeader(stageChannel);
        }
      }

      // ── Embed init (reusable – called by createCard and re-init) ──
      function initEmbed(channel) {
        const wrap = document.getElementById(`embed-${channel}`);
        if (!wrap) return;
        wrap.innerHTML = ''; // destroy previous embed if any

        /* global Twitch */
        const embed = new Twitch.Embed(`embed-${channel}`, {
          channel,
          width:    '100%',
          height:   '100%',
          layout:   'video',
          autoplay: true,
          muted:    true, // always start muted so browser autoplay policy is satisfied
          parent:   [window.location.hostname || 'localhost'],
        });

        const rec = { embed, player: null };
        embeds[channel] = rec;

        embed.addEventListener(Twitch.Embed.VIDEO_READY, () => {
          rec.player = embed.getPlayer();
          rec.player.setMuted(mutedSet.has(channel)); // apply real mute state
          rec.player.play();                          // ensure stream starts
        });
      }

      // ── Card creation ──────────────────────────────────────────
      function createCard(channel) {
        const container = document.getElementById('streams');
        const isMuted   = mutedSet.has(channel);
        const isStage   = stageChannel === channel;

        const card = document.createElement('div');
        card.className = 'stream-card' + (isStage ? ' is-stage' : '');
        card.id = `card-${channel}`;
        card.setAttribute('role', 'region');
        card.setAttribute('aria-label', `${channel} stream`);

        const embedWrap = document.createElement('div');
        embedWrap.className = 'embed-wrap';
        embedWrap.id = `embed-${channel}`;

        card.innerHTML += `
          <div class="card-overlay" aria-hidden="true">
            <div class="overlay-top">
              <span class="card-label">${escHtml(channel)}</span>
              <div class="card-actions">
                <button class="icon-btn mute-btn${isMuted ? ' muted' : ''}"
                        data-ch="${escHtml(channel)}"
                        aria-label="${isMuted ? 'Unmute' : 'Mute'} ${escHtml(channel)}"
                        aria-pressed="${isMuted}"
                        title="${isMuted ? 'Unmute' : 'Mute'}">
                  ${isMuted ? '🔇' : '🔊'}
                </button>
                <button class="icon-btn stage-btn${isStage ? ' staged' : ''}"
                        data-ch="${escHtml(channel)}"
                        aria-label="${isStage ? 'Exit stage for' : 'Set stage for'} ${escHtml(channel)}"
                        aria-pressed="${isStage}"
                        title="${isStage ? 'Exit stage' : 'Set as stage'}">
                  ${isStage ? '⬜' : '⬛'}
                </button>
                <button class="icon-btn wide-btn"
                  data-ch="${escHtml(channel)}"
                  aria-label="${isStage ? 'Use full width for' : 'Set stage first for'} ${escHtml(channel)}"
                  aria-pressed="${isStage && stageFullWidth}"
                  title="${isStage ? 'Use full width' : 'Set stage first'}">
                  ${isStage && stageFullWidth ? '⤡' : '⤢'}
                </button>
                <button class="icon-btn remove-btn"
                        data-ch="${escHtml(channel)}"
                        aria-label="Remove ${escHtml(channel)}"
                        title="Remove stream">✕</button>
              </div>
            </div>
          </div>`;

        card.insertBefore(embedWrap, card.firstChild);
        container.appendChild(card);

        // Bind card overlay events
        card.querySelector('.stage-btn').addEventListener('click',  () => setStage(channel));
        card.querySelector('.wide-btn').addEventListener('click',   () => toggleStageFullWidth(channel));
        card.querySelector('.remove-btn').addEventListener('click', () => removeStream(channel));
        card.querySelector('.mute-btn').addEventListener('click',   () => toggleMute(channel));
        // initEmbed is called by applyLayout after grid dimensions are confirmed
      }

      // ── Layout ─────────────────────────────────────────────────
      function applyLayout() {
        const container = document.getElementById('streams');

        if (streams.length === 0) {
          container.className = 'grid';
          container.style.gridTemplateRows    = '';
          container.style.gridTemplateColumns = '';
          container.style.gridAutoRows        = '';
          container.style.height              = '';
          return;
        }

        const w = container.clientWidth;
        if (!w) { requestAnimationFrame(applyLayout); return; }

        const primary = (stageChannel && streams.includes(stageChannel))
          ? stageChannel : streams[0];
        const others  = streams.filter(c => c !== primary);
        const hasStage = stageChannel && streams.includes(stageChannel);
        if (!hasStage) stageFullWidth = false;

        // Reset height; only the 1-stream full-height branch sets it
        container.style.height = '';
        streams.forEach(ch => {
          const c = document.getElementById(`card-${ch}`);
          if (c) c.classList.remove('full-stage-main');
        });

        if (streams.length === 1) {
          // ── 1 stream (all devices): full viewport height ─────────
          container.className = 'grid';
          container.style.gridTemplateColumns = '1fr';
          container.style.gridTemplateRows    = '1fr';
          container.style.gridAutoRows        = '';
          container.style.height = 'calc(100dvh - var(--header-h) - var(--bar-h))';
          const c = document.getElementById(`card-${streams[0]}`);
          if (c) {
            c.style.gridColumn  = '';
            c.style.gridRow     = '';
            c.style.order       = '';
            c.style.aspectRatio = 'auto';
            c.classList.remove('full-stage-main');
            c.classList.toggle('is-stage', streams[0] === stageChannel);
          }

        } else if (hasStage && stageFullWidth) {
          // ── Full-width stage override (works in grid + stage mode) ─────
          container.className = 'full-stage';
          container.style.gridTemplateColumns = w < 600 ? '1fr' : '1fr 1fr';
          container.style.gridTemplateRows    = '';
          container.style.gridAutoRows        = '';

          const primaryCard = document.getElementById(`card-${stageChannel}`);
          if (primaryCard) {
            primaryCard.style.gridColumn  = '1 / -1';
            primaryCard.style.gridRow     = '1';
            primaryCard.style.order       = '';
            primaryCard.style.aspectRatio = '16 / 9';
            primaryCard.classList.add('is-stage', 'full-stage-main');
          }

          streams.filter(ch => ch !== stageChannel).forEach((ch, i) => {
            const c = document.getElementById(`card-${ch}`);
            if (!c) return;
            c.style.gridColumn  = '';
            c.style.gridRow     = '';
            c.style.order       = i;
            c.style.aspectRatio = '';
            c.classList.remove('is-stage', 'full-stage-main');
          });

        } else if (w < 600) {
          // ── Mobile: single column, 16:9 aspect ratio ────────────
          container.className = 'grid';
          container.style.gridTemplateColumns = '';   // CSS forces 1fr
          container.style.gridTemplateRows    = '';
          container.style.gridAutoRows        = '';
          streams.forEach((ch, i) => {
            const c = document.getElementById(`card-${ch}`);
            if (!c) return;
            c.style.gridColumn  = '';
            c.style.gridRow     = '';
            c.style.order       = i;
            c.style.aspectRatio = ''; // restore CSS rule
            c.classList.remove('full-stage-main');
            c.classList.toggle('is-stage', ch === stageChannel);
          });

        } else if (w < 900) {
          // ── Tablet portrait: 2-col, stage full-width on top ─────
          container.className = 'grid';
          container.style.gridTemplateRows = '';
          container.style.gridAutoRows     = '';
          if (hasStage) {
            container.style.gridTemplateColumns = '1fr 1fr';
            streams.forEach((ch, i) => {
              const c = document.getElementById(`card-${ch}`);
              if (!c) return;
              if (ch === stageChannel) {
                c.style.gridColumn = '1 / -1';
                c.style.gridRow    = '1';
                c.style.order      = '';
              } else {
                c.style.gridColumn = '';
                c.style.gridRow    = '';
                c.style.order      = i;
              }
              c.style.aspectRatio = ''; // restore CSS rule
              c.classList.remove('full-stage-main');
              c.classList.toggle('is-stage', ch === stageChannel);
            });
          } else {
            container.style.gridTemplateColumns = ''; // CSS minmax(280px,1fr)
            streams.forEach((ch, i) => {
              const c = document.getElementById(`card-${ch}`);
              if (!c) return;
              c.style.gridColumn  = '';
              c.style.gridRow     = '';
              c.style.order       = i;
              c.style.aspectRatio = ''; // restore CSS rule
              c.classList.remove('full-stage-main');
              c.classList.toggle('is-stage', false);
            });
          }

        } else if (layoutMode === 'grid') {
          // ── Desktop: classic 2-column grid ───────────────────────
          container.className = 'grid';
          container.style.gridTemplateColumns = '1fr 1fr';
          container.style.gridTemplateRows    = '';
          container.style.gridAutoRows        = '';
          streams.forEach((ch, i) => {
            const c = document.getElementById(`card-${ch}`);
            if (!c) return;
            c.style.gridColumn  = '';
            c.style.gridRow     = '';
            c.style.order       = i;
            c.style.aspectRatio = '';
            c.classList.remove('full-stage-main');
            c.classList.toggle('is-stage', ch === stageChannel);
          });

        } else {
          // ── Wide-stage mode (2+ streams, desktop) ────────────────
          const rowH         = Math.round((w / 12) * 2 * (9 / 16));
          const sidebarItems = others.slice(0, 2);
          const bottomStreams = others.slice(2);

          // 1 sidebar item → spans all 4 rows; 2 items → 2 rows each
          const sideSpan = sidebarItems.length === 1 ? 4 : 2;

          const mediumBottom = bottomStreams.slice(0, 3);
          const smallBottom  = bottomStreams.slice(3);
          const mediumRows   = mediumBottom.length > 0
            ? Math.ceil(mediumBottom.length / 3) * 2 : 0;

          container.className = 'wide-stage';
          container.style.gridTemplateColumns = 'repeat(12, 1fr)';
          container.style.gridTemplateRows    = '';
          container.style.gridAutoRows        = `${rowH}px`;

          // Primary: cols 1–8, rows 1–4
          const primaryCard = document.getElementById(`card-${primary}`);
          if (primaryCard) {
            primaryCard.style.gridColumn  = '1 / span 8';
            primaryCard.style.gridRow     = '1 / span 4';
            primaryCard.style.order       = '';
            primaryCard.style.aspectRatio = 'auto';
            primaryCard.classList.remove('full-stage-main');
            primaryCard.classList.add('is-stage');
          }

          // Sidebar: cols 9–12; adaptive row span
          sidebarItems.forEach((ch, i) => {
            const c = document.getElementById(`card-${ch}`);
            if (!c) return;
            c.style.gridColumn  = '9 / span 4';
            c.style.gridRow     = `${i * sideSpan + 1} / span ${sideSpan}`;
            c.style.order       = '';
            c.style.aspectRatio = 'auto';
            c.classList.remove('is-stage', 'full-stage-main');
          });

          // Medium bottom: 4 cols × 2 rows, 3 per row, starting row 5
          mediumBottom.forEach((ch, i) => {
            const c = document.getElementById(`card-${ch}`);
            if (!c) return;
            c.style.gridColumn  = `${(i % 3) * 4 + 1} / span 4`;
            c.style.gridRow     = `${5 + Math.floor(i / 3) * 2} / span 2`;
            c.style.order       = '';
            c.style.aspectRatio = 'auto';
            c.classList.remove('is-stage', 'full-stage-main');
            if (!mutedSet.has(ch)) { mutedSet.add(ch); setMuted(ch, true); refreshMuteUI(ch); }
          });

          // Small bottom: 2 cols × 1 row, 6 per row
          smallBottom.forEach((ch, i) => {
            const c = document.getElementById(`card-${ch}`);
            if (!c) return;
            c.style.gridColumn  = `${(i % 6) * 2 + 1} / span 2`;
            c.style.gridRow     = `${5 + mediumRows + Math.floor(i / 6)}`;
            c.style.order       = '';
            c.style.aspectRatio = 'auto';
            c.classList.remove('is-stage', 'full-stage-main');
            if (!mutedSet.has(ch)) { mutedSet.add(ch); setMuted(ch, true); refreshMuteUI(ch); }
          });
        }

        // Init embeds for cards not yet initialized
        streams.forEach(ch => { if (!embeds[ch]) initEmbed(ch); });

        // Refresh stage-button icons on every card
        streams.forEach(ch => {
          const btn = document.querySelector(`#card-${CSS.escape(ch)} .stage-btn`);
          if (!btn) return;
          const on = ch === stageChannel;
          btn.textContent = on ? '⬜' : '⬛';
          btn.title       = on ? 'Exit stage' : 'Set as stage';
          btn.setAttribute('aria-pressed', String(on));
          btn.setAttribute('aria-label', `${on ? 'Exit stage for' : 'Set stage for'} ${ch}`);
          btn.classList.toggle('staged', on);
        });

        // Refresh full-width button state on cards and control items
        streams.forEach(ch => {
          const on = ch === stageChannel;
          const isWide = on && stageFullWidth;

          [
            document.querySelector(`#card-${CSS.escape(ch)} .wide-btn`),
            document.querySelector(`#ctrl-${ch} .wide-btn`),
          ].forEach(btn => {
            if (!btn) return;
            btn.style.display = on ? 'inline-flex' : 'none';
            btn.textContent = isWide ? '⤡' : '⤢';
            btn.title = isWide ? 'Exit full width' : 'Use full width';
            btn.setAttribute('aria-pressed', String(isWide));
            btn.setAttribute('aria-label', `${isWide ? 'Exit full width for' : 'Use full width for'} ${ch}`);
            btn.classList.toggle('wide', isWide);
          });
        });
      }

      // Recompute on container resize
      new ResizeObserver(() => applyLayout()).observe(document.getElementById('streams'));

      // Auto-unpin sidebar when window shrinks to mobile width
      let resizeTimer = null;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          if (chatPinned && window.innerWidth <= 600) {
            chatPinned = false;
            save();
            updateChatSidebar();
          }
        }, 150);
      });

      // ── Control bar ────────────────────────────────────────────
      function renderBar() {
        const bar = document.getElementById('ctrl-bar');
        if (!bar) return;

        if (streams.length === 0) { bar.style.display = 'none'; bar.innerHTML = ''; return; }

        bar.style.display = 'flex';
        bar.innerHTML = `<button class="ctrl-clear-all" id="clear-all-btn" title="Remove all streams">Clear all</button>${streams.map(ch => {
          const muted  = mutedSet.has(ch);
          const staged = ch === stageChannel;
          return `
            <div class="ctrl-item${staged ? ' is-stage' : ''}" id="ctrl-${ch}" draggable="true" data-ch="${escHtml(ch)}" aria-label="${escHtml(ch)} stream controls">
              <span class="ctrl-label" title="${escHtml(ch)}">${escHtml(ch)}</span>
              <button class="icon-btn mute-btn${muted ? ' muted' : ''}"
                      data-ch="${escHtml(ch)}"
                      aria-label="${muted ? 'Unmute' : 'Mute'} ${escHtml(ch)}"
                      aria-pressed="${muted}"
                      title="${muted ? 'Unmute' : 'Mute'}">
                ${muted ? '🔇' : '🔊'}
              </button>
              <button class="icon-btn stage-btn${staged ? ' staged' : ''}"
                      data-ch="${escHtml(ch)}"
                      aria-label="${staged ? 'Exit stage for' : 'Set stage for'} ${escHtml(ch)}"
                      aria-pressed="${staged}"
                      title="${staged ? 'Exit stage' : 'Set as stage'}">
                ${staged ? '⬜' : '⬛'}
              </button>
                    <button class="icon-btn wide-btn${staged && stageFullWidth ? ' wide' : ''}"
                      data-ch="${escHtml(ch)}"
                      aria-label="${staged ? 'Use full width for' : 'Set stage first for'} ${escHtml(ch)}"
                      aria-pressed="${staged && stageFullWidth}"
                      title="${staged ? 'Use full width' : 'Set stage first'}"
                      style="display:${staged ? 'inline-flex' : 'none'};">
                ${staged && stageFullWidth ? '⤡' : '⤢'}
                    </button>
              <button class="icon-btn remove-btn"
                      data-ch="${escHtml(ch)}"
                      aria-label="Remove ${escHtml(ch)}"
                      title="Remove stream">✕</button>
            </div>`;
              }).join('')}`;

              document.getElementById('clear-all-btn')?.addEventListener('click', clearAllStreams);

        bar.querySelectorAll('.mute-btn').forEach(b =>
          b.addEventListener('click', () => toggleMute(b.dataset.ch)));
        bar.querySelectorAll('.stage-btn').forEach(b =>
          b.addEventListener('click', () => setStage(b.dataset.ch)));
        bar.querySelectorAll('.wide-btn').forEach(b =>
          b.addEventListener('click', () => toggleStageFullWidth(b.dataset.ch)));
        bar.querySelectorAll('.remove-btn').forEach(b =>
          b.addEventListener('click', () => removeStream(b.dataset.ch)));

        // Drag-to-reorder
        bar.querySelectorAll('.ctrl-item').forEach(item => {
          item.addEventListener('dragstart', e => {
            dragSrc = item.dataset.ch;
            item.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            document.querySelectorAll('.embed-wrap').forEach(w => w.style.pointerEvents = 'none');
          });
          item.addEventListener('dragover', e => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            item.classList.add('drag-over');
          });
          item.addEventListener('dragleave', () => {
            item.classList.remove('drag-over');
          });
          item.addEventListener('drop', e => {
            e.preventDefault();
            item.classList.remove('drag-over');
            const dropCh = item.dataset.ch;
            if (dragSrc && dragSrc !== dropCh) {
              const from = streams.indexOf(dragSrc);
              const to   = streams.indexOf(dropCh);
              if (from !== -1 && to !== -1) {
                streams.splice(from, 1);
                streams.splice(to, 0, dragSrc);
                save();
                applyLayout();
                renderBar();
                renderChatTabs();
              }
            }
            dragSrc = null;
          });
          item.addEventListener('dragend', () => {
            item.classList.remove('dragging');
            bar.querySelectorAll('.ctrl-item').forEach(i => i.classList.remove('drag-over'));
            dragSrc = null;
            document.querySelectorAll('.embed-wrap').forEach(w => w.style.pointerEvents = '');
          });
          item.addEventListener('click', e => {
            if (e.target.closest('button')) return;
            document.getElementById(`card-${item.dataset.ch}`)
              ?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
        });
        refreshMuteAllBtn();
      }

      // ── Mute UI refresh (without full re-render) ───────────────
      function refreshMuteUI(channel) {
        const muted = mutedSet.has(channel);
        [
          document.querySelector(`#card-${CSS.escape(channel)} .mute-btn`),
          document.querySelector(`#ctrl-${channel} .mute-btn`),
        ].forEach(btn => {
          if (!btn) return;
          btn.textContent = muted ? '🔇' : '🔊';
          btn.title       = muted ? 'Unmute' : 'Mute';
          btn.setAttribute('aria-pressed', String(muted));
          btn.setAttribute('aria-label', `${muted ? 'Unmute' : 'Mute'} ${channel}`);
          btn.classList.toggle('muted', muted);
        });
        refreshMuteAllBtn();
      }

      // ── Helpers ────────────────────────────────────────────────
      function updateEmpty() {
        const es = document.getElementById('empty-state');
        if (es) es.style.display = streams.length === 0 ? 'flex' : 'none';
      }

      function escHtml(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function setupChannelSuggest(inputId, listId, onPick = null) {
        const input = document.getElementById(inputId);
        const list  = document.getElementById(listId);
        if (!(input instanceof HTMLInputElement) || !(list instanceof HTMLDivElement)) return () => {};
        const inputEl = input;
        const listEl = list;

        let timer = null;
        let reqId = 0;
        let activeIndex = -1;
        let results = [];

        function closeSuggest() {
          listEl.classList.remove('open');
          listEl.innerHTML = '';
          activeIndex = -1;
          results = [];
        }

        function setActive(index) {
          const items = [...listEl.querySelectorAll('.suggest-item')];
          items.forEach((el, i) => el.classList.toggle('active', i === index));
        }

        function pick(index) {
          const item = results[index];
          if (!item) return;
          addStream(item.login);
          inputEl.value = '';
          closeSuggest();
          if (typeof onPick === 'function') onPick();
        }

        async function fetchSuggest(query) {
          const currentReq = ++reqId;
          listEl.innerHTML = '<div class="suggest-empty">Searching…</div>';
          listEl.classList.add('open');

          try {
            const res = await fetch('https://gql.twitch.tv/gql', {
              method: 'POST',
              headers: {
                'Client-Id': TWITCH_GQL_CLIENT_ID,
                'Content-Type': 'text/plain;charset=UTF-8',
              },
              body: JSON.stringify({
                operationName: 'ChannelTypeahead',
                variables: { q: query },
                query: SEARCH_QUERY,
              }),
            });

            const payload = await res.json();
            if (currentReq !== reqId) return;

            const edges = payload?.data?.searchFor?.channels?.edges || [];
            const seen = new Set();
            results = edges
              .map(e => e?.item)
              .filter(Boolean)
              .map(item => ({
                login: item.login,
                displayName: item.displayName || item.login,
                isLive: Boolean(item.stream?.id),
              }))
              .filter(item => {
                if (!item.login || seen.has(item.login)) return false;
                seen.add(item.login);
                return true;
              })
              .slice(0, 8);

            if (!results.length) {
              listEl.innerHTML = '<div class="suggest-empty">No channels found</div>';
              return;
            }

            listEl.innerHTML = results.map((item, i) => `
              <button type="button" class="suggest-item" data-index="${i}" role="option" aria-selected="false">
                <span class="suggest-main">
                  <span class="suggest-name">${escHtml(item.displayName)}</span>
                  <span class="suggest-login">@${escHtml(item.login)}</span>
                </span>
                <span class="suggest-status${item.isLive ? ' live' : ''}">${item.isLive ? 'LIVE' : 'OFFLINE'}</span>
              </button>
            `).join('');

            [...listEl.querySelectorAll('.suggest-item')].forEach(btn => {
              btn.addEventListener('click', () => pick(Number(btn.getAttribute('data-index'))));
            });
            activeIndex = -1;
          } catch (_) {
            if (currentReq !== reqId) return;
            listEl.innerHTML = '<div class="suggest-empty">Search is currently unavailable</div>';
          }
        }

        input.addEventListener('input', () => {
          clearTimeout(timer);
          const query = inputEl.value.trim().toLowerCase();
          if (query.length < 2) { closeSuggest(); return; }
          timer = setTimeout(() => fetchSuggest(query), 220);
        });

        input.addEventListener('keydown', e => {
          if (!listEl.classList.contains('open') || results.length === 0) return;

          if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIndex = (activeIndex + 1) % results.length;
            setActive(activeIndex);
            return;
          }

          if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIndex = (activeIndex - 1 + results.length) % results.length;
            setActive(activeIndex);
            return;
          }

          if (e.key === 'Enter' && activeIndex >= 0) {
            e.preventDefault();
            pick(activeIndex);
            return;
          }

          if (e.key === 'Escape') {
            closeSuggest();
          }
        });

        document.addEventListener('click', e => {
          const target = e.target;
          if (!(target instanceof Node)) return;
          if (target === inputEl || listEl.contains(target)) return;
          closeSuggest();
        });

        return closeSuggest;
      }

      // ── Layout mode toggle ─────────────────────────────────────
      function toggleLayoutMode() {
        const nextLayoutMode = layoutMode === 'stage' ? 'grid' : 'stage';
        layoutMode = nextLayoutMode;
        save();
        applyLayout();
        refreshLayoutBtn();

        if (nextLayoutMode === 'grid' && stageChannel && streams.includes(stageChannel)) {
          requestAnimationFrame(() => {
            scrollCardIntoViewWithHeader(stageChannel);
          });
        } else if (nextLayoutMode === 'stage') {
          requestAnimationFrame(() => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      }

      function refreshLayoutBtn() {
        const btn = document.getElementById('layout-btn');
        if (!btn) return;
        const isStage = layoutMode === 'stage';
        btn.querySelector('.btn-icon').textContent = isStage ? '⊞' : '⬛';
        btn.querySelector('.btn-text').textContent = isStage ? 'Grid' : 'Stage';
        btn.title = isStage ? 'Switch to 2-column grid' : 'Switch to stage layout';
      }

      // ── Mute all ───────────────────────────────────────────────
      function muteAll() {
        if (streams.length === 0) return;
        const allMuted = streams.every(ch => mutedSet.has(ch));
        streams.forEach(ch => {
          if (allMuted) { mutedSet.delete(ch); setMuted(ch, false); }
          else          { mutedSet.add(ch);    setMuted(ch, true);  }
          refreshMuteUI(ch);
        });
        save();
        refreshMuteAllBtn();
      }

      function refreshMuteAllBtn() {
        const btn = document.getElementById('mute-all-btn');
        if (!btn) return;
        const allMuted = streams.length > 0 && streams.every(ch => mutedSet.has(ch));
        btn.querySelector('.btn-icon').textContent = allMuted ? '🔊' : '🔇';
        btn.querySelector('.btn-text').textContent = allMuted ? 'Unmute All' : 'Mute All';
      }

      // ── Chat sidebar ───────────────────────────────────────────
      function openChatSidebar() {
        chatOpen = true;
        // Default selection: staged stream → first stream → none
        if (!chatChannel || !streams.includes(chatChannel)) {
          chatChannel = stageChannel || streams[0] || null;
        }
        save();
        updateChatSidebar();
      }

      function closeChatSidebar() {
        chatOpen   = false;
        chatPinned = false;
        save();
        updateChatSidebar();
      }

      function toggleChatSidebar() {
        if (chatOpen) closeChatSidebar(); else openChatSidebar();
      }

      function setChatChannel(ch) {
        chatChannel = ch;
        save();
        renderChatTabs();
        renderChatIframe();
      }

      function toggleChatPin() {
        if (window.innerWidth <= 600) return; // no pin on mobile
        chatPinned = !chatPinned;
        save();
        updateChatSidebar();
      }

      function renderChatTabs() {
        const tabsEl = document.getElementById('chat-tabs');
        if (!tabsEl) return;
        tabsEl.innerHTML = streams.map(ch => {
          const active = ch === chatChannel;
          return `<button type="button" class="chat-tab${active ? ' active' : ''}" data-ch="${escHtml(ch)}" role="tab" aria-selected="${active}" title="${escHtml(ch)}">${escHtml(ch)}</button>`;
        }).join('');
        tabsEl.querySelectorAll('.chat-tab').forEach(btn =>
          btn.addEventListener('click', () => setChatChannel(btn.dataset.ch)));
        // Scroll the active tab into view so it's always visible
        tabsEl.querySelector('.chat-tab.active')?.scrollIntoView({ inline: 'nearest', block: 'nearest' });
      }

      function renderChatIframe() {
        const body = document.getElementById('chat-body');
        if (!body) return;
        if (!chatChannel || !streams.includes(chatChannel)) {
          body.innerHTML = streams.length === 0
            ? `<div class="chat-empty"><span class="chat-empty-icon">💬</span><span>Add a stream to view chat</span></div>`
            : `<div class="chat-empty"><span class="chat-empty-icon">💬</span><span>Select a stream above</span></div>`;
          return;
        }
        const hostname = window.location.hostname || 'localhost';
        const src = `https://www.twitch.tv/embed/${encodeURIComponent(chatChannel)}/chat?parent=${encodeURIComponent(hostname)}&darkpopout=true`;
        const existing = body.querySelector('iframe');
        if (existing && existing.getAttribute('src') === src) return; // no change needed
        body.innerHTML = `<iframe src="${escHtml(src)}" title="${escHtml(chatChannel)} chat" allow="autoplay; encrypted-media"></iframe>`;
      }

      function updateChatSidebar() {
        const sidebar = document.getElementById('chat-sidebar');
        const btn     = document.getElementById('chat-btn');
        const pinBtn  = document.getElementById('chat-pin-btn');
        const app     = document.getElementById('app');
        if (!sidebar) return;

        // If open but selected channel was removed, fall back
        if (chatOpen && chatChannel && !streams.includes(chatChannel)) {
          chatChannel = stageChannel || streams[0] || null;
        }
        // If no streams at all, close the sidebar
        if (streams.length === 0) {
          chatOpen   = false;
          chatPinned = false;
        }

        // Pinned only applies on non-mobile (computed, not mutated here)
        const effectivelyPinned = chatOpen && chatPinned && window.innerWidth > 600;
        app?.classList.toggle('chat-pinned', effectivelyPinned);

        sidebar.classList.toggle('open', chatOpen);
        sidebar.setAttribute('aria-hidden', String(!chatOpen));
        if (btn) {
          btn.classList.toggle('chat-active', chatOpen);
          btn.setAttribute('aria-expanded', String(chatOpen));
          btn.title = chatOpen ? 'Close chat' : 'Open chat';
        }
        if (pinBtn) {
          pinBtn.classList.toggle('pinned', chatPinned);
          pinBtn.setAttribute('aria-pressed', String(chatPinned));
          pinBtn.title = chatPinned ? 'Unpin sidebar' : 'Pin sidebar beside streams';
        }
        renderChatTabs();
        renderChatIframe();
      }

      // ── Export / Import ────────────────────────────────────────
      function exportLayout() {
        const data = { streams, stage: stageChannel, muted: [...mutedSet], stageFullWidth, chatOpen, chatChannel, chatPinned };
        const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = 'twitchamore-layout.json';
        a.click();
        URL.revokeObjectURL(url);
      }

      function importLayout(file) {
        const reader = new FileReader();
        reader.onload = e => {
          try {
            const data = JSON.parse(e.target.result);
            if (!Array.isArray(data.streams)) { alert('Invalid layout file.'); return; }

            // Tear down existing streams
            [...streams].forEach(ch => {
              document.getElementById(`card-${ch}`)?.remove();
              delete embeds[ch];
            });
            streams      = [];
            mutedSet     = new Set(Array.isArray(data.muted) ? data.muted : []);
            stageChannel = data.stage || null;
            stageFullWidth = Boolean(data.stageFullWidth);
            chatOpen = Boolean(data.chatOpen);
            chatPinned = Boolean(data.chatPinned) && window.innerWidth > 600;
            chatChannel = (typeof data.chatChannel === 'string' && data.chatChannel) ? data.chatChannel : null;

            data.streams.forEach(ch => {
              if (typeof ch === 'string' && ch.trim()) {
                streams.push(ch.trim().toLowerCase());
                createCard(ch.trim().toLowerCase());
              }
            });

            if (stageChannel && !streams.includes(stageChannel)) stageChannel = null;
            if (chatChannel && !streams.includes(chatChannel)) chatChannel = null;
            if (!stageChannel) stageFullWidth = false;
            save();
            updateEmpty();
            applyLayout();
            renderBar();
            updateChatSidebar();
          } catch (_) { alert('Invalid layout file.'); }
        };
        reader.readAsText(file);
      }

      // ── Init ───────────────────────────────────────────────────
      function init() {
        load();
        let closeDesktopSuggest = () => {};
        let closeMobileSuggest = () => {};

        // Restore streams
        const saved = [...streams];
        streams = [];
        saved.forEach(ch => {
          streams.push(ch);
          createCard(ch);
        });

        updateEmpty();
        applyLayout();
        renderBar();
        refreshLayoutBtn();
        updateChatSidebar();

        // Add-stream form
        document.getElementById('add-form').addEventListener('submit', e => {
          e.preventDefault();
          const input = document.getElementById('channel-input');
          if (!(input instanceof HTMLInputElement)) return;
          addStream(input.value);
          input.value = '';
          closeDesktopSuggest();
        });

        // Export / Import
        document.getElementById('export-btn').addEventListener('click', exportLayout);
        document.getElementById('mute-all-btn').addEventListener('click', muteAll);
        document.getElementById('layout-btn').addEventListener('click', toggleLayoutMode);
        document.getElementById('chat-btn').addEventListener('click', toggleChatSidebar);
        document.getElementById('chat-pin-btn').addEventListener('click', toggleChatPin);
        document.getElementById('chat-close-btn').addEventListener('click', closeChatSidebar);
        document.getElementById('import-btn').addEventListener('click', () =>
          document.getElementById('import-file').click());
        document.getElementById('import-file').addEventListener('change', e => {
          if (e.target.files[0]) importLayout(e.target.files[0]);
          e.target.value = '';
        });

        // Mobile add-bar toggle
        document.getElementById('add-toggle-btn').addEventListener('click', () => {
          const bar = document.getElementById('add-bar');
          const btn = document.getElementById('add-toggle-btn');
          const open = bar.classList.toggle('open');
          bar.setAttribute('aria-hidden', String(!open));
          btn.textContent = open ? '✕' : '+';
          btn.setAttribute('aria-expanded', String(open));
          if (open) document.getElementById('channel-input-mobile').focus();
        });

        document.getElementById('add-form-mobile').addEventListener('submit', e => {
          e.preventDefault();
          const input = document.getElementById('channel-input-mobile');
          if (!(input instanceof HTMLInputElement)) return;
          addStream(input.value);
          input.value = '';
          closeMobileSuggest();
          const bar = document.getElementById('add-bar');
          bar.classList.remove('open');
          bar.setAttribute('aria-hidden', 'true');
          document.getElementById('add-toggle-btn').textContent = '+';
          document.getElementById('add-toggle-btn').setAttribute('aria-expanded', 'false');
        });

        closeDesktopSuggest = setupChannelSuggest('channel-input', 'search-suggest');
        closeMobileSuggest  = setupChannelSuggest('channel-input-mobile', 'search-suggest-mobile', () => {
          const bar = document.getElementById('add-bar');
          bar.classList.remove('open');
          bar.setAttribute('aria-hidden', 'true');
          document.getElementById('add-toggle-btn').textContent = '+';
          document.getElementById('add-toggle-btn').setAttribute('aria-expanded', 'false');
        });
      }

      init();
    </script>
  </body>
</html>
